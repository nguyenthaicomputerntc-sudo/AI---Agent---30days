# Copy file này thành .env và điền API keys thật vào
# File .env sẽ KHÔNG được commit lên GitHub (đã có trong .gitignore)

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Facebook
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_token_here
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here

# Zalo
ZALO_APP_ID=your_zalo_app_id_here
ZALO_APP_SECRET=your_zalo_secret_here

# TikTok
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key_here

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
